{
  "name": "vali-valid-react",
  "version": "1.0.0",
  "description": "React hook for vali-valid — useValiValid with async validation, i18n, criteriaMode, validateOnMount, and full TypeScript support",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.mjs",
  "types": "dist/esm/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.mts",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["react", "vali-valid", "validation", "form-validation", "hook", "typescript", "async-validation"],
  "license": "MIT",
  "author": "Felipe Rafael Montenegro Morriberon <teabajo_ubf@hotmail.com> (https://fm-portafolio.netlify.app/)",
  "homepage": "https://vali-valid.dev/hook-api",
  "bugs": {
    "url": "https://github.com/UBF21/Vali-Valid-React/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/UBF21/Vali-Valid-React.git"
  },
  "sideEffects": false,
  "peerDependencies": {
    "react": ">=16.8.0",
    "vali-valid": ">=3.1.0"
  },
  "devDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "@types/react": "^18.3.0",
    "vali-valid": "^3.1.0",
    "@testing-library/react": "^16.0.0",
    "vitest": "^2.1.9",
    "tsup": "^8.0.0",
    "typescript": "^5.5.4",
    "jsdom": "^25.0.0"
  }
}
